NODE_ENV=development
PORT=3000
API_BASE_URL=https://api.seatsip.in
ALLOWED_ORIGINS=https://app.seatsip.in,seatsip://app

# Runtime database URL (e.g., file:./dev.db)
DATABASE_URL="file:./dev.db"

REDIS_URL=redis://127.0.0.1:6379

JWT_ACCESS_SECRET_CURRENT=
JWT_ACCESS_SECRET_PREVIOUS=
JWT_REFRESH_SECRET_CURRENT=
JWT_REFRESH_SECRET_PREVIOUS=
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=2592000

RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Fallback UPI VPA when a cafe has no upi_id (see GET /cafes/:id/payment-config)
DEFAULT_MERCHANT_UPI=

# Google Sign-In (verify ID tokens; set at least one client ID)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_ID_WEB=
GOOGLE_CLIENT_ID_IOS=
GOOGLE_CLIENT_ID_ANDROID=

# Expo Push API (optional; improves delivery limits)
EXPO_ACCESS_TOKEN=
