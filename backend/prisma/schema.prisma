generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                    String               @id
  name                  String
  email                 String               @unique
  phone                 String?
  password_hash         String
  role                  String               @default("USER")
  avatar                String?
  wallet_balance        Float                @default(0)
  loyalty_points        Int                 @default(0)
  loyalty_tier          String               @default("silver")
  failed_login_count    Int                  @default(0)
  lockout_until         DateTime?
  last_failed_login_at  DateTime?
  is_active             Int                  @default(1)
  google_id             String?              @unique
  auth_provider         String               @default("password")
  push_token            String?
  push_token_updated_at DateTime?
  deletion_scheduled_at DateTime?
  terms_accepted_at      DateTime?
  government_id         String?
  business_license      String?
  experience_years      Int?
  verification_status   String               @default("PENDING")
  created_at            DateTime             @default(now())
  updated_at            DateTime             @updatedAt
  cart_items            CartItem[]
  notifications         Notification[]
  orders                Order[]
  refresh_tokens        RefreshToken[]
  reservations          Reservation[]
  reviews               Review[]
  wallet_txs            WalletTransaction[]
  tier_history          LoyaltyTierHistory[]
  redeemed_rewards      RedeemedReward[]
  owned_cafes           Cafe[]               @relation(name: "UserOwnedCafes")

  @@map("users")
}

model RefreshToken {
  id               String    @id
  user_id          String
  token            String    @unique
  token_hash       String?   @unique
  family_id        String?
  replaced_by_hash String?
  revoked_at       DateTime?
  expires_at       DateTime
  created_at       DateTime  @default(now())
  user             User      @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@index([family_id])
  @@map("refresh_tokens")
}

model Cafe {
  id                String         @id
  name              String
  slug              String         @unique
  description       String?
  address           String
  city              String
  latitude          Float?
  longitude         Float?
  phone             String?
  email             String?
  image_url         String?
  images            String         @default("[]")
  rating            Float          @default(0)
  review_count      Int            @default(0)
  price_level       Int            @default(2)
  is_open           Int            @default(1)
  open_time         String         @default("08:00")
  close_time        String         @default("22:00")
  reservation_slots String         @default("[\"09:00\",\"11:00\",\"13:00\",\"15:00\",\"17:00\",\"19:00\"]")
  wifi              Int            @default(1)
  parking           Int            @default(0)
  pet_friendly      Int            @default(0)
  moods             String         @default("[]")
  tags              String         @default("[]")
  prep_time_minutes Int            @default(15)
  delivery_fee      Float          @default(0)
  min_order         Float          @default(0)
  is_active         Int            @default(1)
  priority          Int            @default(0)
  upi_id            String?
  razorpay_account_id String?
  state             String?
  pincode           String?
  timezone          String         @default("Asia/Kolkata")
  emoji             String?
  cover_color       String?
  discount          String?
  total_seats       Int            @default(0)
  owner_id          String?
  owner             User?          @relation(name: "UserOwnedCafes", fields: [owner_id], references: [id], onDelete: SetNull)
  created_at        DateTime       @default(now())
  updated_at        DateTime       @updatedAt
  cart_items        CartItem[]
  menu_categories   MenuCategory[]
  menu_items        MenuItem[]
  orders            Order[]
  reservations      Reservation[]
  reviews           Review[]
  tables            Table[]
  promotional_banners Banner[]

  @@index([city])
  @@map("cafes")
}

model Table {
  id           String        @id
  cafe_id      String
  table_number String
  capacity     Int           @default(2)
  floor        String        @default("Ground")
  position_x   Float         @default(0)
  position_y   Float         @default(0)
  is_available Int           @default(1)
  created_at   DateTime      @default(now())
  reservations Reservation[]
  cafe         Cafe          @relation(fields: [cafe_id], references: [id], onDelete: Cascade)

  @@map("tables")
}

model MenuCategory {
  id          String     @id
  cafe_id     String
  name        String
  description String?
  sort_order  Int        @default(0)
  is_active   Int        @default(1)
  created_at  DateTime   @default(now())
  cafe        Cafe       @relation(fields: [cafe_id], references: [id], onDelete: Cascade)
  items       MenuItem[]

  @@map("menu_categories")
}

model MenuItem {
  id                String        @id
  cafe_id           String
  category_id       String?
  name              String
  description       String?
  price             Float
  image_url         String?
  is_available      Int           @default(1)
  stock_quantity    Int           @default(999)
  is_veg            Int           @default(0)
  is_popular        Int           @default(0)
  prep_time_minutes Int           @default(10)
  calories          Int?
  caffeine          Int?
  allergens         String        @default("[]")
  customizations    String        @default("[]")
  tags              String        @default("[]")
  explore_category  String?
  created_at        DateTime      @default(now())
  updated_at        DateTime      @updatedAt
  cart_items        CartItem[]
  category          MenuCategory? @relation(fields: [category_id], references: [id])
  cafe              Cafe          @relation(fields: [cafe_id], references: [id], onDelete: Cascade)

  @@index([cafe_id])
  @@map("menu_items")
}

model Order {
  id                   String    @id
  user_id              String
  cafe_id              String
  reservation_id       String?
  status               String    @default("PENDING")
  order_type           String    @default("DINE_IN")
  items                String    @default("[]")
  subtotal             Float     @default(0)
  tax                  Float     @default(0)
  delivery_fee         Float     @default(0)
  discount             Float     @default(0)
  total                Float     @default(0)
  commission           Float     @default(0)
  owner_amount         Float     @default(0)
  payment_status       String?   @default("PENDING")
  payment_method       String?
  razorpay_order_id    String?
  razorpay_payment_id  String?
  special_instructions String?
  estimated_ready_at   DateTime?
  created_at           DateTime  @default(now())
  updated_at           DateTime  @updatedAt
  cafe                 Cafe      @relation(fields: [cafe_id], references: [id])
  user                 User      @relation(fields: [user_id], references: [id])

  @@index([user_id])
  @@index([cafe_id])
  @@map("orders")
}

model Reservation {
  id                String   @id
  user_id           String
  cafe_id           String
  table_id          String?
  date              String
  time              String
  duration_minutes  Int      @default(90)
  party_size        Int
  status            String   @default("PENDING")
  special_requests  String?
  pre_order_items   String   @default("[]")
  pre_order_total   Float    @default(0)
  confirmation_code String   @unique
  cancelled_at      DateTime?
  cancellation_reason String?
  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt
  table             Table?   @relation(fields: [table_id], references: [id])
  cafe              Cafe     @relation(fields: [cafe_id], references: [id])
  user              User     @relation(fields: [user_id], references: [id])

  @@index([user_id])
  @@index([cafe_id])
  @@map("reservations")
}

model Review {
  id         String   @id
  user_id    String
  cafe_id    String
  order_id   String?
  rating     Int
  comment    String?
  images     String   @default("[]")
  created_at DateTime @default(now())
  cafe       Cafe     @relation(fields: [cafe_id], references: [id])
  user       User     @relation(fields: [user_id], references: [id])

  @@unique([user_id, cafe_id])
  @@map("reviews")
}

model CartItem {
  id             String   @id
  user_id        String
  cafe_id        String
  menu_item_id   String
  quantity       Int      @default(1)
  customizations String   @default("{}")
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt
  menu_item      MenuItem @relation(fields: [menu_item_id], references: [id])
  cafe           Cafe     @relation(fields: [cafe_id], references: [id])
  user           User     @relation(fields: [user_id], references: [id])

  @@index([user_id])
  @@map("cart_items")
}

model WalletTransaction {
  id                  String   @id
  user_id             String
  type                String
  amount              Float
  description         String?
  reference_id        String?
  balance_after       Float?
  razorpay_order_id   String?
  razorpay_payment_id String?
  created_at          DateTime @default(now())
  user                User     @relation(fields: [user_id], references: [id])

  @@map("wallet_transactions")
}

model RevokedToken {
  jti        String   @id
  user_id    String
  expires_at DateTime
  revoked_at DateTime @default(now())
  reason     String

  @@index([user_id])
  @@map("revoked_tokens")
}

model PaymentEvent {
  id                  String   @id
  user_id             String?
  order_id            String?
  event_type          String
  payment_method      String
  amount              Float
  refunded_amount     Float    @default(0)
  razorpay_order_id   String?
  razorpay_payment_id String?
  razorpay_refund_id  String?
  status              String
  raw_event_id        String?  @unique
  created_at          DateTime @default(now())

  @@map("payment_events")
}

model AuditLog {
  id            String   @id
  request_id    String
  user_id       String?
  action        String
  resource_type String
  resource_id   String?
  ip_address    String?
  user_agent    String?
  metadata      String   @default("{}")
  created_at    DateTime @default(now())

  @@index([user_id])
  @@map("audit_logs")
}

model Notification {
  id         String   @id
  user_id    String
  title      String
  body       String
  type       String   @default("GENERAL")
  data       String   @default("{}")
  is_read    Int      @default(0)
  created_at DateTime @default(now())
  user       User     @relation(fields: [user_id], references: [id])

  @@map("notifications")
}

model LoyaltyTierHistory {
  id         String   @id
  user_id    String
  from_tier  String
  to_tier    String
  reason     String   @default("points_threshold")
  points_at  Int      @default(0)
  created_at DateTime @default(now())
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@map("loyalty_tier_history")
}

model Reward {
  id             String           @id
  name           String
  icon           String
  category       String           @default("Food & Drink")
  description    String?
  terms          String?                              // fine print
  points_cost    Int
  tier_required  String           @default("SILVER") // SILVER | GOLD | PLATINUM
  stock          Int              @default(-1)        // -1 = unlimited
  total_redeemed Int              @default(0)
  is_active      Int              @default(1)
  valid_from     DateTime?
  valid_until    DateTime?
  cafe_id        String?                              // null = all cafes
  created_at     DateTime         @default(now())
  updated_at     DateTime         @updatedAt
  redemptions    RedeemedReward[]

  @@index([is_active, tier_required])
  @@map("rewards")
}

model RedeemedReward {
  id           String   @id
  user_id      String
  reward_id    String
  order_id     String?             // if applied to an order
  points_spent Int
  status       String   @default("ACTIVE") // ACTIVE | USED | EXPIRED
  expires_at   DateTime?
  used_at      DateTime?
  created_at   DateTime @default(now())
  user         User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  reward       Reward   @relation(fields: [reward_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@index([reward_id])
  @@map("redeemed_rewards")
}

model Banner {
  id                String   @id
  slider_type       String   @default("PROMO") // PROMO | FOOD_PROMO
  tag               String
  tag_icon          String?  // for FOOD_PROMO tag icon (e.g. ⚡)
  tag_color         String   @default("#FFFFFF")
  tag_bg            String?  // for FOOD_PROMO tag pill background
  title             String
  title_accent      String?  // for PROMO title accent
  subtitle          String
  subtitle_color    String?  // for FOOD_PROMO subtitle color
  cta_text          String
  cta_bg            String   @default("#FFFFFF")
  cta_text_color    String   @default("#000000") // maps to ctaText2/ctaTextColor
  bg_color          String   @default("#000000") // maps to bgColor/bg
  overlay_color     String?  // for PROMO overlay color
  stripe_color      String?  // for FOOD_PROMO stripe color
  emoji             String?
  emoji_label       String?
  emoji_label_color String?
  badge             String?  // for PROMO badge
  bg_image          String
  cafe_id           String?
  cafe              Cafe?    @relation(fields: [cafe_id], references: [id], onDelete: SetNull)
  explore_category  String?
  is_active         Int      @default(1)
  sort_order        Int      @default(0)
  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt

  @@map("banners")
}

model SystemSetting {
  id          String   @id
  key         String   @unique
  value       String
  type        String
  category    String
  description String?

  @@map("system_settings")
}

model FeatureFlag {
  id          String   @id
  name        String
  key         String   @unique
  enabled     Boolean
  description String?

  @@map("feature_flags")
}

model ExploreCategory {
  id          String   @id
  name        String   @unique
  slug        String   @unique
  description String?
  tag         String?
  tag_color   String   @default("#FFFFFF")
  tag_bg      String   @default("rgba(45,106,79,0.2)")
  image_url   String?
  sort_order  Int      @default(0)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  @@map("explore_categories")
}
