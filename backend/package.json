{
  "name": "seatsip-backend",
  "version": "1.0.0",
  "description": "SeatSip Backend API",
  "main": "dist/main.js",
  "scripts": {
    "build": "prisma generate && tsc",
    "start": "node dist/main.js",
    "start:cluster": "pm2 start ecosystem.config.js --env production",
    "start:cluster:dev": "pm2 start ecosystem.config.js --env development",
    "stop:cluster": "pm2 stop ecosystem.config.js",
    "reload:cluster": "pm2 reload ecosystem.config.js",
    "restart:cluster": "pm2 restart ecosystem.config.js",
    "logs:cluster": "pm2 logs seatsip-api",
    "monit:cluster": "pm2 monit",
    "status:cluster": "pm2 status",
    "typecheck": "tsc --noEmit",
    "test": "jest --config jest.config.cjs",
    "dev": "prisma generate && ts-node-dev --respawn --transpile-only src/main.ts",
    "postinstall": "prisma generate",
    "db:init": "ts-node src/db/init.ts",
    "db:seed": "ts-node src/db/seed.ts",
    "db:migrate": "prisma migrate deploy",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "db:backup": "ts-node src/db/backup.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "@sentry/node": "^10.57.0",
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "express-async-errors": "^3.1.1",
    "express-rate-limit": "^7.2.0",
    "express-validator": "^7.0.1",
    "google-auth-library": "^9.15.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^8.0.7",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "pino-pretty": "^13.1.3",
    "rate-limit-redis": "^4.2.0",
    "razorpay": "^2.9.6",
    "redis": "^4.7.0",
    "sanitize-html": "^2.13.1",
    "swagger-jsdoc": "^6.3.0",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^9.0.1",
    "zod": "^3.23.8",
    "zxcvbn": "^4.4.2"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.7.5",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.19.41",
    "@types/nodemailer": "^8.0.0",
    "@types/sanitize-html": "^2.11.0",
    "@types/supertest": "^6.0.3",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/uuid": "^9.0.8",
    "@types/zxcvbn": "^4.4.4",
    "jest": "^29.7.0",
    "pm2": "^7.0.1",
    "prisma": "^6.19.3",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.3",
    "eslint": "^8.57.0",
    "@typescript-eslint/parser": "^7.18.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0"
  }
}
