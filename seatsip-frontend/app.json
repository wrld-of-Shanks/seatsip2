{
  "expo": {
    "name": "SeatSip",
    "slug": "seatsip",
    "scheme": "seatsip",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#1C1008"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.seatsip.app",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "SeatSip uses your location to auto-fill your delivery address.",
        "NSPhotoLibraryUsageDescription": "SeatSip lets you choose a photo for your profile.",
        "NSCameraUsageDescription": "SeatSip lets you take a photo for your profile picture.",
        "NSFaceIDUsageDescription": "SeatSip uses Face ID to secure your account.",
        "ITSAppUsesNonExemptEncryption": true
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#E6DDD4"
      },
      "package": "com.seatsip.app",
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "seatsip",
              "host": "*",
              "pathPrefix": "/orders"
            },
            {
              "scheme": "seatsip",
              "host": "*",
              "pathPrefix": "/reservations"
            },
            {
              "scheme": "seatsip",
              "host": "*",
              "pathPrefix": "/explore"
            },
            {
              "scheme": "seatsip",
              "host": "*",
              "pathPrefix": "/profile"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ],
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "VIBRATE",
        "USE_BIOMETRIC"
      ],
      "config": {
        "googleMaps": {
          "apiKey": ""
        }
      }
    },
    "plugins": [
      "expo-video",
      "expo-font",
      "expo-location",
      [
        "expo-font",
        {
          "fonts": [
            "./assets/fonts/BebasNeue-Regular.otf"
          ]
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "SeatSip lets you choose a photo for your profile."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#C8956C"
        }
      ]
    ],
    "web": {
      "bundler": "metro"
    }
  }
}
